        vector3f physics:velocity = (0.7697651, -0.00006218516, -1.888667e-7)
        double radius = 0.25
        quatd xformOp:orient = (0.7109664678573608, -0.000006438383934437297, 0.7032257914543152, 0.00024237569596152753)
        double3 xformOp:scale = (1, 1, 1)
        double3 xformOp:translate = (0.7785515785217285, -0.000011564201486180536, 0.24999985098838806)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:orient", "xformOp:scale"]
