        double3 xformOp:scale = (1, 1, 1)
        double3 xformOp:translate = (-0.05852097272872925, -0.0012045643525198102, 0.15000002086162567)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:orient", "xformOp:scale"]
    }

    def Sphere "Ball" (
        apiSchemas = ["PhysicsCollisionAPI", "PhysicsMeshCollisionAPI", "PhysxCollisionAPI", "PhysicsRigidBodyAPI", "PhysxRigidBodyAPI"]
    )
    {
