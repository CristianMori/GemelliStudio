                int omni:rtx:pt:clampSpp = 64
                uint omni:rtx:pt:limits:maxBounces = 3
                uint omni:rtx:pt:limits:maxGlossyBounces = 3
                uint omni:rtx:pt:maxSamplesPerLaunch = 2073600
                uint omni:rtx:pt:mgpu:maxPixelsPerRegionExponent = 12
                int omni:rtx:pt:samplesPerIteration = 64
                uint omni:rtx:pt:samplesPerPixel = 64
